/* Gramatica de prueba para el parser.
   Cubre: clases, funciones, recursion, listas, expresiones con todos
   los operadores. Las productions binarias de expr son AMBIGUAS por
   diseno -- el PrecedenceRewriter las desambigua usando los niveles
   declarados abajo. */

%token KW_CLASS KW_FUNCTION KW_LET KW_IF KW_ELSE KW_WHILE KW_RETURN
%token KW_TRUE KW_FALSE
%token ID INT FLOAT
%token OP_OR OP_AND OP_EQ OP_NEQ OP_LT OP_GT OP_LE OP_GE
%token OP_PLUS OP_MINUS OP_TIMES OP_DIV OP_MOD OP_NOT OP_ASSIGN
%token LPAREN RPAREN LBRACE RBRACE LBRACKET RBRACKET COMMA SEMI

IGNORE WHITESPACE COMMENT

%left  OP_OR
%left  OP_AND
%left  OP_EQ OP_NEQ
%left  OP_LT OP_GT OP_LE OP_GE
%left  OP_PLUS OP_MINUS
%left  OP_TIMES OP_DIV OP_MOD
%right OP_NOT
%right OP_ASSIGN

%%

program : top_list
        ;

top_list : top_list top
         | top
         ;

top : class_decl
    | function_decl
    | var_decl
    ;

class_decl : KW_CLASS ID LBRACE member_list RBRACE
           ;

member_list : member_list member
            | member
            |
            ;

member : function_decl
       | var_decl
       ;

function_decl : KW_FUNCTION ID LPAREN param_list RPAREN block
              ;

param_list : id_list
           |
           ;

id_list : id_list COMMA ID
        | ID
        ;

var_decl : KW_LET ID OP_ASSIGN expr SEMI
         ;

block : LBRACE stmt_list RBRACE
      ;

stmt_list : stmt_list stmt
          | stmt
          |
          ;

stmt : var_decl
     | if_stmt
     | while_stmt
     | return_stmt
     | expr_stmt
     | block
     ;

if_stmt : KW_IF LPAREN expr RPAREN block
        | KW_IF LPAREN expr RPAREN block KW_ELSE block
        ;

while_stmt : KW_WHILE LPAREN expr RPAREN block
           ;

return_stmt : KW_RETURN expr SEMI
            | KW_RETURN SEMI
            ;

expr_stmt : expr SEMI
          ;

expr : expr OP_OR     expr
     | expr OP_AND    expr
     | expr OP_EQ     expr
     | expr OP_NEQ    expr
     | expr OP_LT     expr
     | expr OP_GT     expr
     | expr OP_LE     expr
     | expr OP_GE     expr
     | expr OP_PLUS   expr
     | expr OP_MINUS  expr
     | expr OP_TIMES  expr
     | expr OP_DIV    expr
     | expr OP_MOD    expr
     | OP_NOT expr
     | expr OP_ASSIGN expr
     | LPAREN expr RPAREN
     | function_call
     | list_literal
     | ID
     | INT
     | FLOAT
     | KW_TRUE
     | KW_FALSE
     ;

function_call : ID LPAREN arg_list RPAREN
              ;

arg_list : expr_list
         |
         ;

expr_list : expr_list COMMA expr
          | expr
          ;

list_literal : LBRACKET expr_list RBRACKET
             | LBRACKET RBRACKET
             ;
